# === Backend (.NET) Environment ===========================================

# Nombre del entorno ASP.NET Core (Development, Testing, Staging, Production, etc.).
ASPNETCORE_ENVIRONMENT=Testing

# Cadena de conexión usada por EF Core.
# Ejemplo para Docker local de PostgreSQL (puedes ajustar host/puerto/credenciales).
ConnectionStrings__Default=Host=localhost;Port=5433;Database=TransporteEscolarDb_Test;Username=postgres;Password=postgres;Include Error Detail=true

# Lista separada por comas de orígenes permitidos para CORS (usar esquema + puerto).
AllowedOrigins=http://localhost:5173

# === Release Notes Hosteado =================================================

# Título mostrado en la notificación global de "Actualización del sistema".
ReleaseNotes__Titulo="Actualización de pagos"

# Descripción detallada (si queda vacío, el hosted service no publica nada).
ReleaseNotes__Descripcion="Se optimizó la UI de pagos mensuales y se corrigieron totales."

# Fecha/hora en UTC de la publicación (ISO8601). Ej: 2026-03-03T15:00:00Z
ReleaseNotes__FechaPublicacionUtc=2026-03-03T15:00:00Z

# URL opcional con más información o release blogpost.
ReleaseNotes__Link=https://tusitio.com/actualizacion

# === Meta WhatsApp Cloud API ===============================================

# Token de acceso del System User (nunca lo publiques).
MetaWhatsApp__AccessToken=WHATSAPP_ACCESS_TOKEN

# Phone Number ID provisto por Meta Business Manager.
MetaWhatsApp__PhoneNumberId=123456789012345

# Versión de Graph API a utilizar (ej. v19.0).
MetaWhatsApp__ApiVersion=v19.0

# Código de idioma de la plantilla aprobada (ej. es_AR, es, en_US).
MetaWhatsApp__LanguageCode=es_AR

# Nombre exacto de la plantilla de recordatorio aprobada.
MetaWhatsApp__TemplateName=recordatorio_pago_mensual

# Token secreto usado por webhook GET para validar la suscripción.
MetaWhatsApp__WebhookVerifyToken=whatsapp-webhook-token
